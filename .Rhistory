# Step 4: Modeling and Prediction (Data Science)
# Load required libraries for modeling
#install.packages("caret")      # For cross-validation and training control
library(caret)      # For cross-validation and training control
library(class)      # For KNN
library(pROC)       # For AUC calculation
# Set seed for reproducibility
set.seed(123)
# Prepare data: Use pima_scaled (standardized, enhanced); exclude non-predictors
predictor_cols <- c("Pregnancies", "Glucose", "BloodPressure", "SkinThickness",
"Insulin", "BMI", "DiabetesPedigreeFunction", "Age",
"BMICategory", "BPCategory")  # Include categories as factors
X_scaled <- pima_scaled[, predictor_cols]
y_scaled <- pima_scaled$Outcome
# For categories: Convert to dummy variables if needed (for models)
X_scaled <- model.matrix(~ . - 1, data = X_scaled)  # One-hot encode factors
# 1. Logistic Regression on Cleaned/Standardized Data
# Train with 10-fold CV
train_control <- trainControl(method = "cv", number = 10, summaryFunction = twoClassSummary, classProbs = TRUE)
lr_model <- train(X_scaled, y_scaled, method = "glm", family = "binomial", trControl = train_control, metric = "ROC")
# Predictions and Metrics
lr_pred <- predict(lr_model, X_scaled, type = "prob")[, "Diabetic"]
lr_auc <- roc(as.numeric(y_scaled == "Diabetic"), lr_pred)$auc
lr_acc <- mean(predict(lr_model, X_scaled) == y_scaled)
print("Logistic Regression (Cleaned):")
print(lr_model)
print(paste("AUC:", round(lr_auc, 3), "Accuracy:", round(lr_acc, 3)))
# Coefficients for interpretability
print("LR Coefficients:")
print(coef(lr_model$finalModel))
# 2. KNN on Cleaned/Standardized Data
# Tune k with CV (k=1:20)
knn_model <- train(X_scaled, y_scaled, method = "knn", trControl = train_control,
tuneGrid = data.frame(k = 1:20), metric = "ROC")
# Best k and Metrics
best_k <- knn_model$bestTune$k
knn_pred <- predict(knn_model, X_scaled, type = "prob")[, "Diabetic"]
knn_auc <- roc(as.numeric(y_scaled == "Diabetic"), knn_pred)$auc
knn_acc <- mean(predict(knn_model, X_scaled) == y_scaled)
print("KNN (Cleaned):")
print(knn_model)
print(paste("Best k:", best_k, "AUC:", round(knn_auc, 3), "Accuracy:", round(knn_acc, 3)))
# 3. Model Selection: Compare via CV Metrics
models_summary <- data.frame(
Model = c("Logistic Regression", "KNN"),
AUC = c(lr_auc, knn_auc),
Accuracy = c(lr_acc, knn_acc)
)
print("Model Comparison (Cleaned Data):")
print(models_summary)
best_model <- ifelse(lr_auc > knn_auc, "Logistic Regression", "KNN")
print(paste("Best Model (by AUC):", best_model))
# 4. Impact of Cleaning: Train LR on Original Data (with 0s)
# To ensure we use the 'original' data with numeric 0/1 Outcome, reload it.
pima_original_raw <- read.csv("diabetes.csv")
# Now, process this raw original data:
pima_original_processed <- pima_original_raw
# Create categories on original raw values
pima_original_processed$BMICategory <- cut(pima_original_processed$BMI,
breaks = c(-Inf, 18.5, 24.9, 29.9, Inf),
labels = c("Underweight", "Normal", "Overweight", "Obese"),
right = FALSE)
pima_original_processed$BPCategory <- cut(pima_original_processed$BloodPressure,
breaks = c(-Inf, 80, 90, Inf),
labels = c("Normal", "Elevated", "High"),
right = FALSE)
# Convert Outcome to factor *after* reloading, so it's fresh numeric 0/1
pima_original_processed$Outcome <- factor(pima_original_processed$Outcome,
levels = c(0, 1),
labels = c("Not_Diabetic", "Diabetic"))
# Standardize numerical columns in pima_original_processed
numerical_cols_original <- c("Pregnancies", "Glucose", "BloodPressure", "SkinThickness", "Insulin", "BMI", "DiabetesPedigreeFunction", "Age")
for (col in numerical_cols_original) {
pima_original_processed[[col]] <- as.vector(scale(pima_original_processed[[col]]))
}
# Prepare X_original and y_original
predictor_cols_original <- c("Pregnancies", "Glucose", "BloodPressure", "SkinThickness",
"Insulin", "BMI", "DiabetesPedigreeFunction", "Age",
"BMICategory", "BPCategory")
X_original_df <- pima_original_processed[, predictor_cols_original]
y_original <- pima_original_processed$Outcome
# Convert categorical predictors to dummy variables
X_original <- model.matrix(~ . - 1, data = X_original_df)
# Manually create stratified folds for y_original to ensure both classes are present in each fold
folds_original <- createFolds(y_original, k = 10, list = TRUE, returnTrain = TRUE)
# Create a new train_control object for the original data that uses these custom folds
train_control_original <- trainControl(method = "cv", number = 10,
summaryFunction = twoClassSummary,
classProbs = TRUE,
index = folds_original)
# Train LR on original using the new train_control_original
lr_original <- train(X_original, y_original, method = "glm", family = "binomial",
trControl = train_control_original, metric = "ROC")
lr_orig_pred <- predict(lr_original, X_original, type = "prob")[, "Diabetic"]
lr_orig_auc <- roc(as.numeric(y_original == "Diabetic"), lr_orig_pred)$auc
lr_orig_acc <- mean(predict(lr_original, X_original) == y_original)
print("Logistic Regression (Original with 0s):")
print(lr_original)
print(paste("AUC:", round(lr_orig_auc, 3), "Accuracy:", round(lr_orig_acc, 3)))
# Comparison Table
comparison_summary <- data.frame(
Data = c("Original (with 0s)", "Cleaned (imputed)"),
AUC = c(lr_orig_auc, lr_auc),
Accuracy = c(lr_orig_acc, lr_acc)
)
print("Impact of Cleaning (LR):")
print(comparison_summary)
# Optional: Confusion Matrices
print("Confusion Matrix - LR Cleaned:")
print(confusionMatrix(predict(lr_model, X_scaled), y_scaled))
print("Confusion Matrix - LR Original:")
print(confusionMatrix(predict(lr_original, X_original), y_original))
# Save models (optional)
save(lr_model, knn_model, file = "diabetes_models.RData")
write.csv(models_summary, "model_summary.csv", row.names = FALSE)
write.csv(comparison_summary, "cleaning_impact.csv", row.names = FALSE)
print("Modeling complete. Best model demonstrates improved performance post-cleaning.")
