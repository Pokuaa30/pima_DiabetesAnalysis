knitr::opts_chunk$set(echo = TRUE)
#Loading the Data and initial exploration.
pima_diabetes = read.csv("diabetes.csv")
pima_diabetes
summary(pima_diabetes)
str(pima_diabetes)
#Loading the Data and initial exploration.
pima_diabetes = read.csv("diabetes.csv")
pima_diabetes
summary(pima_diabetes)
str(pima_diabetes)
#Identifying Biologically Impossible Values
# Finding columns that need imputation
# Check if any column has negative values
sapply(pima_diabetes, function(x) any(x < 0))
# since there are no columns with negative values pregnancies column can be left out.
columns_to_check = pima_diabetes[,setdiff(names(pima_diabetes), c("Outcome","Pregnancies"))]
columns_with_unnatural_values = apply(columns_to_check, 2, function(x) sum(x<=0))
no_of_unnatural_values_per_column = names(columns_to_check)[ columns_with_unnatural_values > 0]
columns_with_unnatural_values
# also age and DiabetesPedigreeFunction can be exempted.
# Finding the best method for imputation.
# First checking for outliers.
par(mfrow=c(2,4))
for(column in no_of_unnatural_values_per_column){
boxplot(pima_diabetes[[column]], main=column, col="lightblue", horizontal=TRUE)
}
# Checking distribution of each column
par(mfrow = c(2,4))  # show multiple plots together
for(column in no_of_unnatural_values_per_column){
hist(pima_diabetes[[column]],
main = paste("Distribution of", column),
xlab = column,
col = "lightgreen",
breaks = 15,
probability = TRUE)
lines(density(pima_diabetes[[column]], na.rm = TRUE),
col = "red", lwd = 2)
}
# For distribution, Glucose, BMI, Blood pressure had a normal distribution while the Insulin and Skin Thickness was skewed
# Now, implement domain-specific cleaning and imputation
# Step 1: Replace biologically impossible 0s with NA in affected columns
# Affected: Glucose, BloodPressure, SkinThickness, Insulin, BMI (exempt Age, DiabetesPedigreeFunction, Pregnancies, Outcome)
affected_cols <- c("Glucose", "BloodPressure", "SkinThickness", "Insulin", "BMI")
pima_clean <- pima_diabetes
for (col in affected_cols) {
pima_clean[[col]] <- ifelse(pima_clean[[col]] == 0, NA_real_, pima_clean[[col]])
}
# Verify NAs introduced
print("NAs after replacement:")
sapply(pima_clean, function(x) sum(is.na(x)))
# Step 2: Imputation - Use median for most (robust to skew/outliers)
# For Insulin (fundamental and skewed): Domain-specific stratified median by Outcome (0: non-diabetic ~lower insulin; 1: diabetic ~higher)
# Compute stratified medians for Insulin
insulin_medians <- aggregate(Insulin ~ Outcome, data = pima_clean, FUN = median, na.rm = TRUE)
print("Stratified Insulin medians by Outcome:")
print(insulin_medians)
# Compute overall medians for other columns
medians_other <- sapply(affected_cols[affected_cols != "Insulin"], function(col) {
median(pima_clean[[col]], na.rm = TRUE)
})
print("Medians for other columns:")
print(medians_other)
# Step 3: Apply imputation
# For non-Insulin columns: Replace NA with overall median
for (col in affected_cols[affected_cols != "Insulin"]) {
pima_clean[[col]] <- ifelse(is.na(pima_clean[[col]]), medians_other[col], pima_clean[[col]])
}
# For Insulin: Replace NA with stratified median based on Outcome
pima_clean$Insulin <- ifelse(is.na(pima_clean$Insulin),
insulin_medians$Insulin[match(pima_clean$Outcome, insulin_medians$Outcome)],
pima_clean$Insulin)
# Step 4: Verify cleaning (no NAs, check summaries)
print("Summary after domain-specific imputation:")
summary(pima_clean)
# Now, implement domain-specific cleaning and imputation
# Step 1: Replace biologically impossible 0s with NA in affected columns
# Affected: Glucose, BloodPressure, SkinThickness, Insulin, BMI (exempt Age, DiabetesPedigreeFunction, Pregnancies, Outcome)
affected_cols <- c("Glucose", "BloodPressure", "SkinThickness", "Insulin", "BMI")
pima_clean <- pima_diabetes
for (col in affected_cols) {
pima_clean[[col]] <- ifelse(pima_clean[[col]] == 0, NA_real_, pima_clean[[col]])
}
# Verify NAs introduced
print("NAs after replacement:")
sapply(pima_clean, function(x) sum(is.na(x)))
# Step 2: Imputation - Use median for most (robust to skew/outliers)
# For Insulin (fundamental and skewed): Domain-specific stratified median by Outcome (0: non-diabetic ~lower insulin; 1: diabetic ~higher)
# Compute stratified medians for Insulin
insulin_medians <- aggregate(Insulin ~ Outcome, data = pima_clean, FUN = median, na.rm = TRUE)
print("Stratified Insulin medians by Outcome:")
print(insulin_medians)
# Compute overall medians for other columns
medians_other <- sapply(affected_cols[affected_cols != "Insulin"], function(col) {
median(pima_clean[[col]], na.rm = TRUE)
})
print("Medians for other columns:")
print(medians_other)
# Step 3: Apply imputation
# For non-Insulin columns: Replace NA with overall median
for (col in affected_cols[affected_cols != "Insulin"]) {
pima_clean[[col]] <- ifelse(is.na(pima_clean[[col]]), medians_other[col], pima_clean[[col]])
}
# For Insulin: Replace NA with stratified median based on Outcome
pima_clean$Insulin <- ifelse(is.na(pima_clean$Insulin),
insulin_medians$Insulin[match(pima_clean$Outcome, insulin_medians$Outcome)],
pima_clean$Insulin)
# Step 4: Verify cleaning (no NAs, check summaries)
print("Summary after domain-specific imputation:")
summary(pima_clean)
# Optional: Re-plot distributions to confirm improvements
par(mfrow = c(2,4))
for(column in affected_cols){
hist(pima_clean[[column]],
main = paste("Cleaned Distribution of", column),
xlab = column,
col = "lightblue",
breaks = 15,
probability = TRUE)
lines(density(pima_clean[[column]], na.rm = TRUE),
col = "red", lwd = 2)
}
# Step 5: Save cleaned CSV
write.csv(pima_clean, "cleaned_diabetes.csv", row.names = FALSE)
print("Cleaned CSV saved as 'cleaned_diabetes.csv'")
# Step 6: Create categories BEFORE standardization (using original scales)
# BMI Categories using WHO thresholds
pima_clean$BMICategory <- cut(pima_clean$BMI,
breaks = c(-Inf, 18.5, 24.9, 29.9, Inf),
labels = c("Underweight", "Normal", "Overweight", "Obese"),
right = FALSE)
print("BMI Category Summary:")
table(pima_clean$BMICategory)
# Blood Pressure Categories (Diastolic BP thresholds)
pima_clean$BPCategory <- cut(pima_clean$BloodPressure,
breaks = c(-Inf, 80, 90, Inf),
labels = c("Normal", "Elevated", "High"),
right = FALSE)
print("BP Category Summary:")
table(pima_clean$BPCategory)
# Transform Target Variable (Outcome) to Factor with Labels
pima_clean$Outcome <- factor(pima_clean$Outcome,
levels = c(0, 1),
labels = c("Not_Diabetic", "Diabetic")) # Changed labels here
# Verify
print("Outcome as Factor:")
str(pima_clean$Outcome)
table(pima_clean$Outcome)
# Step 7: Standardize numerical variables (z-score: mean=0, sd=1)
# Numerical features: All except Outcome and new categories
numerical_cols <- c("Pregnancies", "Glucose", "BloodPressure", "SkinThickness", "Insulin", "BMI", "DiabetesPedigreeFunction", "Age")
# Apply scale() function for standardization
pima_scaled <- pima_clean
for (col in numerical_cols) {
pima_scaled[[col]] <- as.vector(scale(pima_clean[[col]]))  # scale() returns matrix; convert to vector
}
# Verify standardization (means ~0, sds ~1)
print("Means after standardization:")
sapply(pima_scaled[numerical_cols], mean)
print("SDs after standardization:")
sapply(pima_scaled[numerical_cols], sd)
# Step 8: Final Summary and Save Enhanced Dataset
print("Full Summary after all transformations:")
summary(pima_scaled)
# Save the enhanced dataset
write.csv(pima_scaled, "enhanced_diabetes.csv", row.names = FALSE)
print("Enhanced CSV saved as 'enhanced_diabetes.csv'")
# Optional: Visualize new categories
par(mfrow = c(1, 2))
barplot(table(pima_clean$BMICategory), main = "BMI Categories", col = "lightblue")
barplot(table(pima_clean$BPCategory), main = "BP Categories", col = "lightgreen")
# Step 3: Visualization and Exploration (with ggplot2)
# Load ggplot2 and patchwork for side-by-side plots
library(ggplot2)
#install.packages("patchwork") # Install patchwork
library(patchwork)  # For combining plots side-by-side
# Prepare data: Original (pima_diabetes) has numeric Outcome; convert for consistency
pima_diabetes$Outcome <- factor(pima_diabetes$Outcome, levels = c(0, 1), labels = c("Not_Diabetic", "Diabetic")) # Changed labels here
pima_diabetes$Dataset <- "Original (with 0s)"
pima_clean$Dataset <- "Cleaned (imputed)"
# Combine for faceting
pima_combined <- rbind(
pima_diabetes[, c("Glucose", "BMI", "Age", "Outcome", "Dataset")],
pima_clean[, c("Glucose", "BMI", "Age", "Outcome", "Dataset")]
)
# 1. Density plots for Glucose (side-by-side: original vs cleaned)
p1_original <- ggplot(pima_diabetes, aes(x = Glucose, fill = Outcome)) +
geom_density(alpha = 0.6) +
labs(title = "Glucose Density (Original)", x = "Glucose (mg/dL)", y = "Density") +
theme_minimal() +
scale_fill_manual(values = c("Not_Diabetic" = "blue", "Diabetic" = "red"))
p1_cleaned <- ggplot(pima_clean, aes(x = Glucose, fill = Outcome)) +
geom_density(alpha = 0.6) +
labs(title = "Glucose Density (Cleaned)", x = "Glucose (mg/dL)", y = "Density") +
theme_minimal() +
scale_fill_manual(values = c("Not_Diabetic" = "blue", "Diabetic" = "red"))
p1_combined_plot <- p1_original + p1_cleaned + plot_layout(ncol = 2)
print(p1_combined_plot)
# 2. Comparing Distributions: BMI and Age by Outcome (violin plots, faceted by Dataset)
p2 <- ggplot(pima_combined, aes(x = Outcome, y = BMI, fill = Outcome)) +
geom_violin(alpha = 0.7) +
facet_wrap(~ Dataset, scales = "free") +
labs(title = "BMI Distribution by Outcome", x = "Outcome", y = "BMI (kg/m²)") +
theme_minimal() +
scale_fill_manual(values = c("Not_Diabetic" = "blue", "Diabetic" = "red"))
print(p2)
p3 <- ggplot(pima_combined, aes(x = Outcome, y = Age, fill = Outcome)) +
geom_violin(alpha = 0.7) +
facet_wrap(~ Dataset, scales = "free") +
labs(title = "Age Distribution by Outcome", x = "Outcome", y = "Age (years)") +
theme_minimal() +
scale_fill_manual(values = c("Not_Diabetic" = "blue", "Diabetic" = "red"))
print(p3)
# 3. Correlation Between Predictors: Heatmap for numerical variables
# Numerical columns for correlation
num_cols <- c("Pregnancies", "Glucose", "BloodPressure", "SkinThickness", "Insulin", "BMI", "DiabetesPedigreeFunction", "Age")
# Compute correlations
cor_original <- cor(pima_diabetes[, num_cols], use = "complete.obs")
cor_cleaned <- cor(pima_clean[, num_cols], use = "complete.obs")
# Function to create heatmap
create_heatmap <- function(cor_matrix, title) {
cor_long <- as.data.frame(as.table(cor_matrix))
names(cor_long) <- c("Var1", "Var2", "Correlation")
cor_long$Var1 <- as.character(cor_long$Var1)
cor_long$Var2 <- as.character(cor_long$Var2)
ggplot(cor_long, aes(x = Var2, y = Var1, fill = Correlation)) +
geom_tile() +
geom_text(aes(label = round(Correlation, 2)), color = "white", size = 3) +
scale_fill_gradient2(low = "blue", high = "red", mid = "white", midpoint = 0, limit = c(-1,1), name = "Correlation") +
labs(title = title, x = "", y = "") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1))
}
p4_original <- create_heatmap(cor_original, "Correlation Heatmap (Original)")
p4_cleaned <- create_heatmap(cor_cleaned, "Correlation Heatmap (Cleaned)")
p4_combined <- p4_original + p4_cleaned + plot_layout(ncol = 2)
print(p4_combined)
